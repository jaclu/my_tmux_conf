{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [

        {
            "type": "bashdb",
            "request": "launch",
            "name": "Bash-Debug tools/myt",
            "cwd": "${workspaceFolder}",
            "program": "${workspaceFolder}/tools/myt",
            "args": ["-2"]
        },

        {
            "name": "Python Debugger: Build tmux.conf",
            "type": "debugpy",
            "request": "launch",
            "program": "t2.py",
            "console": "integratedTerminal",
            "env": "T2_ENV=1",
            "args": "-r '/home/jaclu/t2/tmux/tmux.conf' -t /home/jaclu/.asdf/installs/tmux/3.6b/bin/tmux"
        },

        {
            "name": "Python Debugger: rt",
            "type": "debugpy",
            "request": "launch",
            "program": "tools/rt",
            "console": "integratedTerminal",
            "args": "-2 hetz2/jacdroid/hetz2"
        }
    ]
}
